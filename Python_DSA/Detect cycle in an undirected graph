def isCyclic(n, edges):
    graph = [[] for _ in range(n)]

    for u,v in edges:
        graph[u].append(v)
        graph[v].append(u)

    visited = [False] * n

    def dfs(node,parent):
        visited[node] = True
        for nei in graph[node]:
            if not visited[nei]:
                if dfs(nei,node):
                    return True
            elif nei != parent:
                return True
        else:
            return False

    for i in range(n):
        if not visited[i]:
            if dfs(i,-1):
                return True
    return False
