def candy_allocation(ratings):
    n = len(ratings)
    lis = [1] * n

    for i in range(1,n):
        if ratings[i] > ratings[i-1]:
            lis[i] = lis[i-1] + 1
        
    for i in range(n-2, -1, -1):
        if ratings[i] > ratings[i+1]:
            lis[i] = max(lis[i], lis[i+1]+1)

    return sum(lis)
