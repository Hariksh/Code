def numIslands(mat,n,m):
    ans = 0
    def helper(i,j):
        if i < 0 or j < 0 or i >= n or j >= m:
            return
        if mat[i][j] != 1:
            return 
        mat[i][j] = 0
        helper(i+1,j)
        helper(i-1,j)
        helper(i,j+1)
        helper(i,j-1)

    for i in range(n):
        for j in range(m):
            if mat[i][j] == 1:
                helper(i,j)
                ans += 1
    return ans
