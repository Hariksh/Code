def mazeObstacles(m, n, obstacleGrid):
    mod = (10 ** 9) + 7
    dp = {}

    def helper(i,j):
        if i < 0 or j < 0:
            return 0
        
        if  obstacleGrid[i][j] == 1:
            return 0 

        if (i,j) in dp:
            return dp[(i,j)]

        if i == 0 and j == 0:
            return 1

        a = helper(i-1,j)
        b = helper(i,j-1)

        dp[(i,j)] =  a + b
        return dp[(i,j)]

    return helper(m-1,n-1) % mod
