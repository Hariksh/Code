def all_partitions(s):
    res = []
    curr_path = []
    def helper(s):
        if not s:
            res.append(curr_path[:])
            return
        for i in range(len(s)):
            curr_path.append(s[:i+1])
            helper(s[i+1:])
            curr_path.pop()
    helper(s)
    return res
